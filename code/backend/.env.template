# TORQ-e Backend Environment Configuration
# Copy to .env and fill in your values

# ============================================================================
# FLASK
# ============================================================================
FLASK_ENV=production
FLASK_APP=torq_e_backend.py
DEBUG=False

# ============================================================================
# GITHUB API
# ============================================================================
GITHUB_TOKEN=your_github_token_here

# ============================================================================
# BRAVE SEARCH API
# ============================================================================
BRAVE_API_KEY=your_brave_api_key_here

# ============================================================================
# GOOGLE CLOUD APIS
# ============================================================================
GOOGLE_CSE_KEY=your_google_cse_key_here
GOOGLE_CSE_CX=your_google_cse_cx_here
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# ============================================================================
# DATABASE (PostgreSQL on Railway)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/torq_e

# ============================================================================
# BACKEND SERVER
# ============================================================================
TORQ_E_BACKEND_URL=http://localhost:5000

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
